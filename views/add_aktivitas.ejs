<div class="container-fluid pb-5">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0 text-dark"><i class="bi bi-journal-plus"></i> Tambah Aktivitas Kolaborasi</h4>
        <a href="/aktivitas" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Kembali ke Daftar</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body bg-white">
            <form action="/aktivitas" method="POST" enctype="multipart/form-data">
                <input type="hidden" name="action" value="add">
                
                <div class="row g-4">
                    <!-- Bagian Kiri -->
                    <div class="col-md-6">
                        <h6 class="text-primary border-bottom pb-2 mb-3">A. Informasi Utama</h6>
                        
                        <div class="mb-3">
                            <label class="form-label">1. Nama Aktivitas Kolaborasi</label>
                            <input type="text" name="nama_aktivitas" class="form-control" required placeholder="Judul/Nama Kegiatan">
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">2. Deskripsi Aktivitas</label>
                            <textarea name="deskripsi" class="form-control" rows="3" required placeholder="Penjelasan singkat mengenai aktivitas..."></textarea>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">3. Jenis Kolaborasi</label>
                            <select name="jenis_kolaborasi" class="form-select" required>
                                <option value="">-- Pilih Jenis --</option>
                                <option value="Kolaborasi">Kolaborasi</option>
                                <option value="Non Kolaborasi">Non Kolaborasi</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">4. Status Aktivitas</label>
                            <select name="status" class="form-select" required>
                                <option value="Usulan">1. Usulan</option>
                                <option value="Analisis">2. Analisis</option>
                                <option value="Persetujuan Perencanaan">3. Persetujuan Perencanaan</option>
                                <option value="Forum Group Discussion">4. Forum Group Discussion</option>
                                <option value="Perencanaan">5. Perencanaan</option>
                                <option value="Perjanjian Kerjasama">6. Perjanjian Kerjasama</option>
                                <option value="Adendum Perjanjian Kerjasama">7. Adendum Perjanjian Kerjasama</option>
                                <option value="Pengembangan">8. Pengembangan</option>
                                <option value="SIT/UAT">9. SIT/UAT</option>
                                <option value="Go Live">10. Go Live</option>
                                <option value="Monitoring implementasi">11. Monitoring implementasi</option>
                                <option value="Selesai">12. Selesai</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">5. Output (Keluaran)</label>
                            <textarea name="output" class="form-control" rows="2" placeholder="Sistem baru, API dokumen, dll..." required></textarea>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">6. Outcome (Hasil/Dampak)</label>
                            <textarea name="outcome" class="form-control" rows="2" placeholder="Efisiensi waktu, peningkatan layanan..." required></textarea>
                        </div>

                        <h6 class="text-primary border-bottom pb-2 mt-4 mb-3">B. Filter Aspek Terkait (Multi-Pilihan)</h6>
                        <div class="mb-3">
                            <label class="form-label text-muted small">Pilih Pilar</label>
                            <div id="container_pilar" class="border p-2 mb-2 bg-light rounded" style="max-height: 150px; overflow-y: auto;">
                                <small class="text-muted">Memuat data pilar...</small>
                            </div>
                            
                            <label class="form-label text-muted small">Pilih Kelompok</label>
                            <div id="container_kelompok" class="border p-2 mb-2 bg-light rounded" style="max-height: 150px; overflow-y: auto;">
                                <small class="text-muted">Pilih pilar terlebih dahulu...</small>
                            </div>
                            
                            <label class="form-label">4. Aspek Terpilih (Bisa pilih lebih dari satu)</label>
                            <div id="container_aspek" class="border p-2 bg-light rounded" style="max-height: 150px; overflow-y: auto;">
                                <small class="text-muted">Pilih kelompok terlebih dahulu...</small>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Bagian Kanan -->
                    <div class="col-md-6">
                        <h6 class="text-primary border-bottom pb-2 mb-3">C. Stakeholder & Mitra</h6>
                        
                        <div class="mb-3">
                            <label class="form-label text-muted small">Pilih Deputi (Unit Internal)</label>
                            <div id="container_deputi" class="border p-2 mb-2 bg-light rounded" style="max-height: 150px; overflow-y: auto;">
                                <small class="text-muted">Memuat data deputi...</small>
                            </div>

                            <label class="form-label">7. Direktorat / Unit Internal</label>
                            <div id="container_direktorat" class="border p-2 bg-light rounded" style="max-height: 150px; overflow-y: auto;">
                                <small class="text-muted">Pilih deputi terlebih dahulu...</small>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">8. Nama Mitra</label>
                                <input type="text" name="nama_mitra" class="form-control" placeholder="Contoh: PT. ABC / Kemen PUPR" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">9. Jenis Mitra</label>
                                <select name="jenis_mitra" class="form-select" required>
                                    <option value="">-- Pilih --</option>
                                    <option value="Pemerintah Pusat">Pemerintah Pusat</option>
                                    <option value="Pemerintah Daerah">Pemerintah Daerah</option>
                                    <option value="Kemitraan Non Pemerintah">Kemitraan Non Pemerintah</option>
                                </select>
                            </div>
                        </div>

                        <h6 class="text-primary border-bottom pb-2 mt-2 mb-3">D. Pelaksanaan & Teknis IT</h6>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">10. Prediksi Pelaksanaan</label>
                                <input type="week" name="prediksi_pelaksanaan" class="form-control" value="" required>
                                <small class="text-muted">Pilih Minggu & Tahun</small>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">11. Target Pelaksanaan</label>
                                <input type="week" name="target_pelaksanaan" class="form-control" value="" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">12. Teknik Integrasi</label>
                            <select name="teknik_integrasi" class="form-select" required>
                                <option value="">-- Pilih Teknik IT --</option>
                                <option value="RESTful API (JSON)">RESTful API (JSON)</option>
                                <option value="SOAP (XML)">SOAP (XML)</option>
                                <option value="GraphQL">GraphQL</option>
                                <option value="Webhooks">Webhooks</option>
                                <option value="File Transfer (SFTP/ETL)">File Transfer (SFTP/ETL)</option>
                                <option value="Direct Database Link">Direct Database Link</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">13. Pola Integrasi</label>
                            <select name="pola_integrasi" class="form-select" required>
                                <option value="">-- Pilih Pola --</option>
                                <option value="Synchronous (Real-time P2P)">Synchronous (Real-time P2P)</option>
                                <option value="Asynchronous (Message Queue / Kafka)">Asynchronous (Message Queue / Kafka)</option>
                                <option value="Batch Processing (Terjadwal)">Batch Processing (Terjadwal)</option>
                                <option value="Hub and Spoke (ESB/API Gateway)">Hub and Spoke (ESB/API Gateway)</option>
                            </select>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">14. Risiko IT</label>
                                <select name="risiko" class="form-select" required>
                                    <option value="">-- Pilih Risiko --</option>
                                    <option value="Kebocoran Data (Security)">Kebocoran Data (Security)</option>
                                    <option value="Latensi / Downtime (Availability)">Latensi / Downtime</option>
                                    <option value="Inkompatibilitas Format Data">Inkompatibilitas Format Data</option>
                                    <option value="Kegagalan API Pihak Ketiga">Kegagalan API Pihak Ketiga</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">15. Kontrol / Mitigasi</label>
                                <select name="kontrol" class="form-select" required>
                                    <option value="">-- Pilih Kontrol --</option>
                                    <option value="Enkripsi & IAM">Enkripsi & IAM</option>
                                    <option value="Load Balancer & HA">Load Balancer & HA</option>
                                    <option value="Data Transformation Layer">Data Transformation Layer</option>
                                    <option value="Circuit Breaker Pattern">Circuit Breaker Pattern</option>
                                </select>
                            </div>
                        </div>

                        <h6 class="text-primary border-bottom pb-2 mt-4 mb-3">E. Catatan & Dokumen Pendukung</h6>
                        
                        <div class="mb-3">
                            <label class="form-label">16. Catatan Tambahan</label>
                            <textarea name="catatan" class="form-control" rows="3" placeholder="Masukkan catatan tambahan jika ada..."></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label d-flex justify-content-between align-items-center mb-2">
                                <span>17. Dokumen Lampiran (Max 10MB per berkas)</span>
                                <button type="button" class="btn btn-xs btn-outline-success py-1 px-2 text-xs" id="btnTambahDokumen" style="font-size: 0.8rem;"><i class="bi bi-plus-circle"></i> Tambah Dokumen</button>
                            </label>
                            <div id="containerDokumen">
                                <div class="dokumen-row mb-2 d-flex gap-2 align-items-center">
                                    <input type="file" name="dokumen" class="form-control input-dokumen-file">
                                    <button type="button" class="btn btn-outline-danger btn-hapus-dokumen" style="display:none;"><i class="bi bi-trash"></i></button>
                                </div>
                            </div>
                            <small class="text-muted d-block mt-1">Format file: PDF, DOCX, XLSX, ZIP, Gambar, dll. Maksimal ukuran file 10MB per berkas.</small>
                        </div>

                    </div>
                </div>
                
                <hr class="mt-4 mb-4">
                <div class="d-flex justify-content-end gap-2">
                    <button type="reset" class="btn btn-outline-secondary"><i class="bi bi-arrow-counterclockwise"></i> Reset</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Simpan Aktivitas</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    let dataPilar = [];
    let dataKelompok = [];
    let dataAspek = [];
    let dataOrganisasi = {};

    const conPilar = document.getElementById('container_pilar');
    const conKelompok = document.getElementById('container_kelompok');
    const conAspek = document.getElementById('container_aspek');

    const conDeputi = document.getElementById('container_deputi');
    const conDirektorat = document.getElementById('container_direktorat');

    document.addEventListener("DOMContentLoaded", () => {
        fetch('/api/data').then(res => res.json()).then(data => {
            dataPilar = data.pilar;
            dataKelompok = data.kelompok;
            dataAspek = data.aspek;
            dataOrganisasi = data.organisasi;
            
            if(Array.isArray(dataPilar)) {
                let html = '';
                dataPilar.forEach((p, idx) => {
                    html += `<div class="form-check">
                        <input class="form-check-input pilar-cb" type="checkbox" value="${p.kode_pilar}" id="pilar_${idx}">
                        <label class="form-check-label" for="pilar_${idx}">${p.kode_pilar} - ${p.nama_pilar}</label>
                    </div>`;
                });
                conPilar.innerHTML = html;
            }
            
            let listDeputi = [];
            try {
                listDeputi = dataOrganisasi.komisioner.unit_di_bawah.filter(u => u.jabatan);
            } catch(e) { console.warn("Format JSON Organisasi berbeda", e); }

            if(listDeputi.length > 0) {
                let html = '';
                listDeputi.forEach((dep, idx) => {
                    html += `<div class="form-check">
                        <input class="form-check-input deputi-cb" type="checkbox" value="${idx}" id="deputi_${idx}">
                        <label class="form-check-label" for="deputi_${idx}">${dep.jabatan}</label>
                    </div>`;
                });
                conDeputi.innerHTML = html;
            }
        });

        conPilar.addEventListener("change", function(e) {
            if(e.target.classList.contains('pilar-cb')) {
                const selectedPilars = Array.from(conPilar.querySelectorAll('input:checked')).map(cb => cb.value);
                
                conKelompok.innerHTML = '';
                conAspek.innerHTML = '<small class="text-muted">Pilih kelompok terlebih dahulu...</small>';

                if(selectedPilars.length > 0 && Array.isArray(dataKelompok)) {
                    const filteredKel = dataKelompok.filter(k => selectedPilars.includes(k.kode_pilar));
                    if(filteredKel.length > 0) {
                        let html = '';
                        filteredKel.forEach((k, idx) => {
                            html += `<div class="form-check">
                                <input class="form-check-input kel-cb" type="checkbox" value="${k.kode_kelompok}" id="kel_${idx}">
                                <label class="form-check-label" for="kel_${idx}">${k.kode_kelompok} - ${k.nama_kelompok}</label>
                            </div>`;
                        });
                        conKelompok.innerHTML = html;
                    } else {
                        conKelompok.innerHTML = '<small class="text-muted">Tidak ada kelompok untuk pilar ini.</small>';
                    }
                } else {
                    conKelompok.innerHTML = '<small class="text-muted">Pilih pilar terlebih dahulu...</small>';
                }
            }
        });

        conKelompok.addEventListener("change", function(e) {
            if(e.target.classList.contains('kel-cb')) {
                const selectedKel = Array.from(conKelompok.querySelectorAll('input:checked')).map(cb => cb.value);
                conAspek.innerHTML = '';

                if(selectedKel.length > 0 && Array.isArray(dataAspek)) {
                    const filteredAspek = dataAspek.filter(a => selectedKel.includes(a.kode_kelompok));
                    if(filteredAspek.length > 0) {
                        let html = '';
                        filteredAspek.forEach((a, idx) => {
                            html += `<div class="form-check">
                                <input class="form-check-input aspek-cb" name="aspek[]" type="checkbox" value="${a.nama_aspek}" id="aspek_${idx}">
                                <label class="form-check-label" for="aspek_${idx}">[${a.kode_aspek}] ${a.nama_aspek}</label>
                            </div>`;
                        });
                        conAspek.innerHTML = html;
                    } else {
                         conAspek.innerHTML = '<small class="text-muted">Aspek kosong di kelompok ini.</small>';
                    }
                } else {
                    conAspek.innerHTML = '<small class="text-muted">Pilih kelompok terlebih dahulu...</small>';
                }
            }
        });

        conDeputi.addEventListener("change", function(e) {
            if(e.target.classList.contains('deputi-cb')) {
                const selectedIdxs = Array.from(conDeputi.querySelectorAll('input:checked')).map(cb => cb.value);
                conDirektorat.innerHTML = '';

                if(selectedIdxs.length > 0) {
                    let html = '';
                    let d_idx = 0;
                    selectedIdxs.forEach(idx => {
                        const direkData = dataOrganisasi.komisioner.unit_di_bawah.filter(u => u.jabatan)[idx].direktorat;
                        if(direkData && direkData.length > 0) {
                            direkData.forEach(dir => {
                                let valText = dataOrganisasi.komisioner.unit_di_bawah.filter(u => u.jabatan)[idx].jabatan + " | " + dir.nama;
                                html += `<div class="form-check">
                                    <input class="form-check-input dir-cb" name="unit_internal[]" type="checkbox" value="${valText}" id="dir_${d_idx}">
                                    <label class="form-check-label" for="dir_${d_idx}">${dir.nama} <small class="text-muted">(${dataOrganisasi.komisioner.unit_di_bawah.filter(u => u.jabatan)[idx].jabatan})</small></label>
                                </div>`;
                                d_idx++;
                            });
                        }
                    });
                    if (html === '') {
                        conDirektorat.innerHTML = '<small class="text-muted">Tidak ada direktorat di deputi ini.</small>';
                    } else {
                        conDirektorat.innerHTML = html;
                    }
                } else {
                    conDirektorat.innerHTML = '<small class="text-muted">Pilih deputi terlebih dahulu...</small>';
                }
            }
        });

        // Handler untuk Multiple Upload Dokumen secara Dinamis
        const containerDokumen = document.getElementById('containerDokumen');
        const btnTambahDokumen = document.getElementById('btnTambahDokumen');

        if (btnTambahDokumen && containerDokumen) {
            btnTambahDokumen.addEventListener('click', function() {
                const newRow = document.createElement('div');
                newRow.className = 'dokumen-row mb-2 d-flex gap-2 align-items-center';
                newRow.innerHTML = `
                    <input type="file" name="dokumen" class="form-control input-dokumen-file">
                    <button type="button" class="btn btn-outline-danger btn-hapus-dokumen"><i class="bi bi-trash"></i></button>
                `;
                containerDokumen.appendChild(newRow);
                updateHapusButtons();
            });

            containerDokumen.addEventListener('click', function(e) {
                if (e.target.closest('.btn-hapus-dokumen')) {
                    const row = e.target.closest('.dokumen-row');
                    row.remove();
                    updateHapusButtons();
                }
            });

            containerDokumen.addEventListener('change', function(e) {
                if (e.target.classList.contains('input-dokumen-file')) {
                    const file = e.target.files[0];
                    if (file && file.size > 10 * 1024 * 1024) {
                        alert('Ukuran file melebihi batas 10MB! Silakan pilih file yang lebih kecil.');
                        e.target.value = '';
                    }
                }
            });

            function updateHapusButtons() {
                const rows = containerDokumen.querySelectorAll('.dokumen-row');
                rows.forEach((row, index) => {
                    const deleteBtn = row.querySelector('.btn-hapus-dokumen');
                    if (rows.length === 1) {
                        deleteBtn.style.display = 'none';
                    } else {
                        deleteBtn.style.display = 'inline-block';
                    }
                });
            }
        }
    });
</script>
