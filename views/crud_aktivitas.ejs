<div class="container-fluid pb-5">
    
    <!-- DHTMLX Gantt Dependencies -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.4/moment.min.js"></script>
    <script src="https://cdn.dhtmlx.com/gantt/edge/dhtmlxgantt.js"></script>
    <link rel="stylesheet" href="https://cdn.dhtmlx.com/gantt/edge/dhtmlxgantt.css">

    <style>
        /* Custom DHTMLX Gantt Overdue Style */
        .gantt-overdue { background-color: #dc3545 !important; border-color: #b02a37 !important; }
        .gantt-overdue .gantt_task_progress { background-color: #b02a37 !important; }
        
        /* Ensure normal tasks are blue */
        .gantt_task_line { background-color: #0d6efd; border-color: #0a58ca; }
        .gantt_task_progress { background-color: #0a58ca; }
    </style>
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0 text-dark"><i class="bi bi-activity"></i> Aktivitas Kolaborasi</h4>
        <a href="/aktivitas/add" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Tambah Aktivitas</a>
    </div>

    <% if(msg == "success") { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> Data aktivitas berhasil disimpan!
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    <% } %>
    
    <% if(msg == "deleted") { %>
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="bi bi-trash"></i> Data aktivitas berhasil dihapus.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    <% } %>

    <!-- Nav tabs -->
    <ul class="nav nav-tabs mb-4" id="aktivitasTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="daftar-tab" data-bs-toggle="tab" data-bs-target="#daftar" type="button" role="tab"><i class="bi bi-table"></i> Daftar Data</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="timeline-tab" data-bs-toggle="tab" data-bs-target="#timeline" type="button" role="tab"><i class="bi bi-calendar-range"></i> Timeline</button>
        </li>
    </ul>

    <div class="tab-content" id="aktivitasTabContent">
        
        <!-- Tab Daftar -->
        <div class="tab-pane fade show active" id="daftar" role="tabpanel">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h6 class="mb-0 fw-bold">Daftar Data Aktivitas</h6>
                        <div class="d-flex gap-2">
                            <select id="filterKolaborasi" class="form-select form-select-sm" style="width: auto;">
                                <option value="">Semua Kolaborasi</option>
                                <option value="Kolaborasi">Kolaborasi</option>
                                <option value="Non Kolaborasi">Non Kolaborasi</option>
                            </select>
                            <select id="filterStatus" class="form-select form-select-sm" style="width: auto;">
                                <option value="">Semua Status</option>
                                <option value="Usulan">Usulan</option>
                                <option value="Analisis">Analisis</option>
                                <option value="Persetujuan Perencanaan">Persetujuan Perencanaan</option>
                                <option value="Forum Group Discussion">Forum Group Discussion</option>
                                <option value="Perencanaan">Perencanaan</option>
                                <option value="Perjanjian Kerjasama">Perjanjian Kerjasama</option>
                                <option value="Adendum Perjanjian Kerjasama">Adendum Perjanjian Kerjasama</option>
                                <option value="Pengembangan">Pengembangan</option>
                                <option value="SIT/UAT">SIT/UAT</option>
                                <option value="Go Live">Go Live</option>
                                <option value="Monitoring implementasi">Monitoring implementasi</option>
                                <option value="Selesai">Selesai</option>
                            </select>
                            <input type="text" id="searchAktivitas" class="form-control form-control-sm" placeholder="Cari aktivitas, unit, mitra..." style="width: 250px;">
                        </div>
                    </div>
                </div>
                <div class="card-body bg-white table-responsive">
            <table class="table table-bordered table-striped table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>No</th>
                        <th>Nama Aktivitas</th>
                        <th>Kolaborasi</th>
                        <th>Unit & Mitra</th>
                        <th>Pelaksanaan</th>
                        <th>Aspek</th>
                        <th>Integrasi IT</th>
                        <th class="text-center">Status</th>
                        <th>Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(!listData || listData.length === 0) { %>
                    <tr><td colspan="8" class="text-center text-muted py-4">Belum ada data aktivitas.</td></tr>
                    <% } else { 
                        let no = 1;
                        listData.forEach(row => { 
                    %>
                    <tr>
                        <td><%= no++ %></td>
                        <td>
                            <strong><%= row.nama_aktivitas %></strong><br>
                            <small class="text-muted"><%= row.deskripsi %></small>
                        </td>
                        <td><span class="badge bg-<%= row.jenis_kolaborasi == "Kolaborasi" ? "success" : "secondary" %>"><%= row.jenis_kolaborasi %></span></td>
                        <td>
                            <% let unitStr = ''; try { let u = JSON.parse(row.unit_internal); unitStr = Array.isArray(u) ? u.join(', ') : u; } catch(e) { unitStr = row.unit_internal; } %>
                            <small><b>Unit:</b> <%= unitStr %></small><br>
                            <small><b>Mitra:</b> <%= row.nama_mitra %> (<%= row.jenis_mitra %>)</small>
                        </td>
                        <td>
                            <small>P: <%= row.prediksi_pelaksanaan %></small><br>
                            <small>T: <%= row.target_pelaksanaan %></small>
                        </td>
                        <td>
                            <% if (row.aspek && Array.isArray(row.aspek) && row.aspek.length > 0) { row.aspek.forEach(asp => { %><span class="badge bg-info text-dark mb-1 me-1"><%= asp %></span><% }) } else { %>-<% } %>
                        </td>
                        <td>
                            <small><b>Teknik:</b> <%= row.teknik_integrasi || '-' %></small><br>
                            <small><b>Pola:</b> <%= row.pola_integrasi || '-' %></small>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-primary"><%= row.status || 'Usulan' %></span>
                        </td>
                        <td>
                            <div class="d-flex gap-1 flex-wrap">
                                <button type="button" class="btn btn-sm btn-info text-white" data-bs-toggle="modal" data-bs-target="#viewModal<%= row.id %>" title="View Details"><i class="bi bi-eye"></i></button>
                                <a href="/aktivitas/edit/<%= row.id %>" class="btn btn-sm btn-primary" title="Edit"><i class="bi bi-pencil-square"></i></a>
                                <a href="/aktivitas/delete/<%= row.id %>" class="btn btn-sm btn-danger" onclick="return confirm('Yakin hapus data ini?')" title="Delete"><i class="bi bi-trash"></i></a>
                            </div>

                            <!-- View Modal -->
                            <div class="modal fade text-start" id="viewModal<%= row.id %>" tabindex="-1">
                                <div class="modal-dialog modal-lg">
                                    <div class="modal-content">
                                        <div class="modal-header bg-info text-white">
                                            <h5 class="modal-title"><i class="bi bi-info-circle"></i> Detail Aktivitas</h5>
                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body text-dark" style="white-space: normal;">
                                            <div class="row">
                                                <div class="col-md-6 mb-3">
                                                    <p class="mb-1 text-muted small">Nama Aktivitas</p>
                                                    <h6><%= row.nama_aktivitas %></h6>
                                                    
                                                    <p class="small mb-1"><strong>Deskripsi:</strong> <%= row.deskripsi %></p>
                                                    <p class="small mb-1"><strong>Kolaborasi:</strong> <%= row.jenis_kolaborasi %></p>
                                                    <p class="small mb-1"><strong>Status:</strong> <span class="badge bg-primary"><%= row.status || 'Usulan' %></span></p>
                                                    
                                                    <p class="small mb-1"><strong>Output:</strong> <%= row.output || '-' %></p>
                                                    <p class="small"><strong>Outcome:</strong> <%= row.outcome || '-' %></p>
                                                    
                                                    <p class="mb-1 mt-3 text-muted small">Aspek Terkait</p>
                                                    <div>
                                                        <% if (row.aspek && Array.isArray(row.aspek) && row.aspek.length > 0) { row.aspek.forEach(asp => { %><span class="badge bg-info text-dark mb-1 me-1"><%= asp %></span><% }) } else { %>-<% } %>
                                                    </div>
                                                </div>
                                                <div class="col-md-6 mb-3 border-start">
                                                    <p class="mb-1 text-muted small">Unit Internal & Mitra</p>
                                                    <p class="small mb-1"><strong>Unit Internal:</strong> <%= unitStr %></p>
                                                    <p class="small"><strong>Mitra:</strong> <%= row.nama_mitra %> (<%= row.jenis_mitra %>)</p>
                                                    
                                                    <p class="mb-1 mt-3 text-muted small">Jadwal Pelaksanaan</p>
                                                    <p class="small mb-1"><strong>Prediksi:</strong> <%= row.prediksi_pelaksanaan %></p>
                                                    <p class="small"><strong>Target:</strong> <%= row.target_pelaksanaan %></p>
                                                    
                                                    <p class="mb-1 mt-3 text-muted small">Integrasi IT</p>
                                                    <p class="small mb-1"><strong>Teknik Integrasi:</strong> <%= row.teknik_integrasi || '-' %></p>
                                                    <p class="small"><strong>Pola Integrasi:</strong> <%= row.pola_integrasi || '-' %></p>
                                                    
                                                    <p class="mb-1 mt-3 text-muted small">Manajemen Risiko</p>
                                                    <p class="small mb-1"><strong>Risiko:</strong> <%= row.risiko || '-' %></p>
                                                    <p class="small"><strong>Kontrol / Mitigasi:</strong> <%= row.kontrol || '-' %></p>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Tutup</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- End View Modal -->
                        </td>
                    </tr>
                    <% }) } %>
                </tbody>
            </table>
        </div>
    </div>
        </div>

        <!-- Tab Timeline -->
        <div class="tab-pane fade" id="timeline" role="tabpanel">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-bold">Gantt Chart Aktivitas</h6>
                    <div class="btn-group btn-group-sm" role="group">
                        <button type="button" class="btn btn-outline-secondary" onclick="changeView('Week')">Week</button>
                        <button type="button" class="btn btn-outline-secondary active" onclick="changeView('Month')">Month</button>
                        <button type="button" class="btn btn-outline-secondary" onclick="changeView('Year')">Year</button>
                    </div>
                </div>
                <div class="card-body bg-white">
                    <div id="gantt-target" style="width: 100%; height: 500px;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Parse data dari EJS ke script
const rawData = <%- JSON.stringify(listData || []) %>;

// Fungsi untuk konversi '2026-W27' ke tanggal valid YYYY-MM-DD
function getWeekDateRange(weekString, isEnd = false) {
    if(!weekString) return null;
    const parts = weekString.split('-W');
    if(parts.length !== 2) return null;
    const year = parts[0];
    const week = parts[1];
    
    // moment.js parses ISO weeks automatically
    const date = moment(`${year}-W${week}`, 'YYYY-[W]WW');
    if(isEnd) {
        // Frappe gantt needs the end date, we add 6 days to represent end of week
        return date.add(6, 'days').format('YYYY-MM-DD');
    }
    return date.format('YYYY-MM-DD');
}

document.addEventListener("DOMContentLoaded", function() {
    let tasks = [];
    const now = moment();

    rawData.forEach((row, i) => {
        let start = getWeekDateRange(row.prediksi_pelaksanaan);
        let end = getWeekDateRange(row.target_pelaksanaan, true);
        
        // Fallback jika tgl kosong, gunakan hari ini
        if(!start) start = now.format('YYYY-MM-DD');
        if(!end) end = moment(start).add(1, 'month').format('YYYY-MM-DD');

        // Deteksi Overdue
        const endDateObj = moment(end);
        const isOverdue = endDateObj.isBefore(now, 'day');
        
        // Progress mock: 100% jika sudah lewat end date dan tidak "overdue" tapi krn ini simple, kasih aja 50% default
        let progress = 0;
        
        tasks.push({
            id: row.id || `task-${i}`,
            text: row.nama_aktivitas, // DHTMLX uses 'text'
            start_date: start,        // DHTMLX uses 'start_date'
            end_date: end,            // DHTMLX uses 'end_date'
            progress: progress,
            is_overdue: isOverdue,
            status: row.status || 'Usulan'
        });
    });

    if(tasks.length > 0) {
        // Configurasi DHTMLX Gantt
        gantt.config.date_format = "%Y-%m-%d";
        gantt.config.columns = [
            { 
                name: "text", 
                label: "Daftar Aktivitas", 
                width: "*", 
                tree: true,
                template: function(task) {
                    return "<strong>" + task.text + "</strong>";
                }
            }
        ];

        // Format waktu: atas Bulan, bawah Minggu
        gantt.config.scales = [
            { unit: "month", step: 1, format: "%F %Y" },
            { unit: "week", step: 1, format: "Week %W" }
        ];

        // Tampilkan teks status di dalam balok grafik
        gantt.templates.task_text = function(start, end, task) {
            return task.status;
        };

        // Kustomisasi warna untuk overdue
        gantt.templates.task_class = function(start, end, task) {
            if(task.is_overdue) return "gantt-overdue";
            return "";
        };

        gantt.init("gantt-target");
        gantt.parse({ data: tasks });
    } else {
        document.getElementById('gantt-target').innerHTML = "<p class='text-center py-4 text-muted'>Belum ada aktivitas untuk ditampilkan di timeline.</p>";
    }
});

function changeView(mode) {
    if(typeof gantt !== 'undefined') {
        if (mode === 'Week') {
            gantt.config.scales = [
                { unit: "week", step: 1, format: "Week %W" },
                { unit: "day", step: 1, format: "%d %M" }
            ];
        } else if (mode === 'Month') {
            gantt.config.scales = [
                { unit: "month", step: 1, format: "%F %Y" },
                { unit: "week", step: 1, format: "Week %W" }
            ];
        } else if (mode === 'Year') {
            gantt.config.scales = [
                { unit: "year", step: 1, format: "%Y" },
                { unit: "month", step: 1, format: "%M" }
            ];
        }
        gantt.render();
        
        // Toggle active class di button
        document.querySelectorAll('.btn-group button').forEach(btn => btn.classList.remove('active'));
        event.target.classList.add('active');
    }
}

// Fitur Pencarian & Filter Aktivitas
document.addEventListener("DOMContentLoaded", function() {
    const searchInput = document.getElementById('searchAktivitas');
    const filterKolab = document.getElementById('filterKolaborasi');
    const filterStat = document.getElementById('filterStatus');
    const tableBody = document.querySelector('#daftar table tbody');
    
    function applyFilters() {
        if (!searchInput || !filterKolab || !tableBody) return;
        
        const searchText = searchInput.value.toLowerCase();
        const kolabVal = filterKolab.value.toLowerCase();
        const statVal = filterStat ? filterStat.value.toLowerCase() : '';
        const rows = tableBody.querySelectorAll('tr');
        
        rows.forEach(row => {
            // Abaikan baris "Belum ada data"
            if (row.cells.length === 1) return;
            
            const textContent = row.textContent.toLowerCase();
            // Kolom jenis kolaborasi ada di index 2
            const jenisKolabText = row.cells[2] ? row.cells[2].textContent.toLowerCase().trim() : '';
            // Kolom status ada di index 7
            const statusText = row.cells[7] ? row.cells[7].textContent.toLowerCase().trim() : '';
            
            const matchSearch = textContent.includes(searchText);
            const matchKolab = (kolabVal === '') || (jenisKolabText === kolabVal);
            const matchStat = (statVal === '') || (statusText === statVal);
            
            if (matchSearch && matchKolab && matchStat) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }
    
    if (searchInput) searchInput.addEventListener('keyup', applyFilters);
    if (filterKolab) filterKolab.addEventListener('change', applyFilters);
    if (filterStat) filterStat.addEventListener('change', applyFilters);
});
</script>