<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistem Informasi Kolaborasi IT</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
            color: #334155;
            overflow-x: hidden;
        }
        
        /* Sidebar Styles */
        #sidebar {
            min-width: 260px;
            max-width: 260px;
            min-height: 100vh;
            background-color: #0f172a;
            color: #cbd5e1;
            transition: all 0.3s;
        }

        #sidebar .sidebar-header {
            padding: 20px;
            background: #1e293b;
            border-bottom: 1px solid #334155;
            color: #fff;
            font-weight: 700;
            font-size: 1.1rem;
        }

        #sidebar ul.components {
            padding: 10px 0;
        }

        #sidebar ul li a {
            padding: 12px 20px;
            font-size: 0.95rem;
            display: block;
            color: #cbd5e1;
            text-decoration: none;
            transition: all 0.3s;
        }

        #sidebar ul li a:hover {
            color: #fff;
            background: #1e293b;
            border-left: 4px solid #3b82f6;
        }

        #sidebar ul li.active > a {
            color: #fff;
            background: #1e293b;
            border-left: 4px solid #3b82f6;
            font-weight: 600;
        }

        #sidebar ul li a i {
            margin-right: 10px;
            font-size: 1.1rem;
        }
        
        .sidebar-heading {
            padding: 10px 20px 5px;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: #64748b;
            font-weight: 600;
        }

        /* Content Styles */
        #content {
            width: 100%;
            min-height: 100vh;
            transition: all 0.3s;
            display: flex;
            flex-direction: column;
        }

        /* Navbar Styles */
        .navbar-custom {
            background-color: #fff;
            box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
            padding: 12px 24px;
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .user-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: #e2e8f0;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #475569;
            font-weight: bold;
        }

        /* Main Content Area */
        .main-content {
            padding: 24px;
            flex-grow: 1;
        }

        /* Card Customization */
        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            overflow: hidden;
        }
        
        .card-header {
            background-color: #fff;
            border-bottom: 1px solid #e2e8f0;
            padding: 16px 20px;
            font-weight: 600;
            color: #1e293b;
        }
    </style>
</head>
<body>

<div class="d-flex">
    <!-- Sidebar -->
    <nav id="sidebar">
        <div class="sidebar-header">
            <i class="bi bi-hdd-network"></i> SI-KOLABORASI
        </div>

        <ul class="list-unstyled components">
            <div class="sidebar-heading">Menu Utama</div>
            <li class="<%= path === '/aktivitas' ? 'active' : '' %>">
                <a href="/aktivitas"><i class="bi bi-activity"></i> Aktivitas Kolaborasi</a>
            </li>
            <li class="<%= path === '/organisasi' ? 'active' : '' %>">
                <a href="/organisasi"><i class="bi bi-diagram-3"></i> Struktur Organisasi</a>
            </li>
            
            <div class="sidebar-heading mt-3">Master Data</div>
            <li class="<%= path === '/manajemen/pilar' ? 'active' : '' %>">
                <a href="/manajemen/pilar"><i class="bi bi-columns-gap"></i> Manajemen Pilar</a>
            </li>
            <li class="<%= path === '/manajemen/kelompok' ? 'active' : '' %>">
                <a href="/manajemen/kelompok"><i class="bi bi-collection"></i> Manajemen Kelompok</a>
            </li>
            <li class="<%= path === '/manajemen/aspek' ? 'active' : '' %>">
                <a href="/manajemen/aspek"><i class="bi bi-tags"></i> Manajemen Aspek</a>
            </li>

            <div class="sidebar-heading mt-3">Pengaturan</div>
            <li class="<%= path === '/manajemen/users' ? 'active' : '' %>">
                <a href="/manajemen/users"><i class="bi bi-people"></i> Manajemen User</a>
            </li>
            <li class="<%= path === '/ganti_password' ? 'active' : '' %>">
                <a href="/ganti_password"><i class="bi bi-shield-lock"></i> Ganti Password</a>
            </li>
        </ul>
    </nav>

    <!-- Page Content -->
    <div id="content">
        <!-- Top Navbar -->
        <nav class="navbar navbar-expand-lg navbar-custom">
            <div class="container-fluid">
                <button type="button" id="sidebarCollapse" class="btn btn-light shadow-sm d-md-none">
                    <i class="bi bi-list"></i>
                </button>
                
                <div class="ms-auto d-flex align-items-center">
                    <% if (user) { %>
                    <div class="dropdown">
                        <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle text-dark" id="dropdownUser1" data-bs-toggle="dropdown" aria-expanded="false">
                            <div class="user-avatar">
                                <%= user.username.charAt(0).toUpperCase() %>
                            </div>
                            <span class="ms-2 fw-medium"><%= user.username %></span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="dropdownUser1">
                            <li><a class="dropdown-item text-danger" href="/logout"><i class="bi bi-box-arrow-right"></i> Logout</a></li>
                        </ul>
                    </div>
                    <% } %>
                </div>
            </div>
        </nav>

        <!-- Main Content -->
        <div class="main-content">
            <%- body %>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        const sidebarCollapseBtn = document.getElementById('sidebarCollapse');
        if(sidebarCollapseBtn) {
            sidebarCollapseBtn.addEventListener('click', function() {
                document.getElementById('sidebar').classList.toggle('active');
            });
        }
    });
</script>
</body>
</html>
