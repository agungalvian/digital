<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0 text-dark"><i class="bi bi-tags"></i> Manajemen Aspek</h4>
    </div>

    <div class="row">
        <!-- Tabel Data -->
        <div class="col-md-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="mb-0 fw-bold">Daftar Aspek</h6>
                        <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addModal">
                            <i class="bi bi-plus-circle"></i> Tambah Aspek
                        </button>
                    </div>
                    <input type="text" id="searchAspek" class="form-control form-control-sm" placeholder="Cari nama aspek, kode, pilar, atau kelompok...">
                </div>
                <div class="card-body table-responsive p-0" style="max-height: 600px; overflow-y: auto;">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light" style="position: sticky; top: 0; z-index: 1;">
                            <tr>
                                <th class="ps-3">Kode Aspek</th>
                                <th>Kelompok</th>
                                <th>Pilar</th>
                                <th>Nama Aspek</th>
                                <th>Status</th>
                                <th class="text-end pe-3">Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(!data || data.length === 0) { %>
                                <tr><td colspan="5" class="text-center text-muted py-3">Belum ada aspek.</td></tr>
                            <% } else { %>
                                <% data.forEach(row => { %>
                                    <tr>
                                        <td class="ps-3"><span class="badge bg-primary"><%= row.kode_aspek %></span></td>
                                        <td><span class="badge bg-secondary"><%= row.kode_kelompok %></span></td>
                                        <td><span class="badge bg-dark"><%= row.kode_pilar %></span></td>
                                        <td class="fw-medium"><%= row.nama_aspek %></td>
                                        <td>
                                            <% if(row.status_ketersediaan === 'Belum Tersedia') { %>
                                                <span class="badge bg-danger">Belum Tersedia</span>
                                            <% } else { %>
                                                <span class="badge bg-success"><%= row.status_ketersediaan || 'Tersedia' %></span>
                                            <% } %>
                                        </td>
                                        <td class="text-end pe-3">
                                            <div class="d-flex justify-content-end gap-1">
                                                <button type="button" class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#viewModal<%= row.kode_aspek.replace(/\./g, '') %>" title="View Details"><i class="bi bi-eye"></i></button>
                                                <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editModal<%= row.kode_aspek.replace(/\./g, '') %>" title="Edit"><i class="bi bi-pencil"></i></button>
                                                <form action="/manajemen/aspek" method="POST" class="d-inline mb-0" onsubmit="return confirm('Yakin hapus aspek ini?')">
                                                    <input type="hidden" name="action" value="delete">
                                                    <input type="hidden" name="kode_aspek" value="<%= row.kode_aspek %>">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                                                </form>
                                            </div>
                                        </td>
                                            <!-- View Modal -->
                                            <div class="modal fade text-start" id="viewModal<%= row.kode_aspek.replace(/\./g, '') %>" tabindex="-1">
                                                <div class="modal-dialog">
                                                    <div class="modal-content">
                                                        <div class="modal-header bg-info text-white">
                                                            <h5 class="modal-title"><i class="bi bi-info-circle"></i> Detail Aspek</h5>
                                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                                        </div>
                                                        <div class="modal-body">
                                                            <p><strong>Kode Aspek:</strong> <br><%= row.kode_aspek %></p>
                                                            <p><strong>Nama Aspek:</strong> <br><%= row.nama_aspek %></p>
                                                            <p><strong>Keterangan:</strong> <br><%= row.keterangan_aspek %></p>
                                                            <p><strong>Pilar:</strong> <br><%= row.kode_pilar %></p>
                                                            <p><strong>Kelompok:</strong> <br><%= row.kode_kelompok %></p>
                                                            <p><strong>Status:</strong> <br>
                                                                <% if(row.status_ketersediaan === 'Belum Tersedia') { %>
                                                                    <span class="badge bg-danger">Belum Tersedia</span>
                                                                <% } else { %>
                                                                    <span class="badge bg-success"><%= row.status_ketersediaan || 'Tersedia' %></span>
                                                                <% } %>
                                                            </p>
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Tutup</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <!-- End View Modal -->
                                            
                                            <!-- Edit Modal -->
                                            <div class="modal fade text-start" id="editModal<%= row.kode_aspek.replace(/\./g, '') %>" tabindex="-1">
                                                <div class="modal-dialog">
                                                    <div class="modal-content">
                                                        <form action="/manajemen/aspek" method="POST">
                                                            <div class="modal-header">
                                                                <h5 class="modal-title">Edit Aspek</h5>
                                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                            </div>
                                                            <div class="modal-body">
                                                                <input type="hidden" name="action" value="edit">
                                                                <input type="hidden" name="id_lama" value="<%= row.kode_aspek %>">
                                                                
                                                                <div class="mb-3">
                                                                    <label class="form-label">Nama Aspek</label>
                                                                    <input type="text" name="nama_aspek" class="form-control" value="<%= row.nama_aspek %>" required>
                                                                </div>
                                                                <div class="mb-3">
                                                                    <label class="form-label">Keterangan Aspek</label>
                                                                    <textarea name="keterangan_aspek" class="form-control" required><%= row.keterangan_aspek %></textarea>
                                                                </div>
                                                                <div class="mb-3">
                                                                    <label class="form-label">Status Ketersediaan</label>
                                                                    <select name="status_ketersediaan" class="form-select" required>
                                                                        <option value="Tersedia" <%= (row.status_ketersediaan === 'Tersedia' || !row.status_ketersediaan) ? 'selected' : '' %>>Tersedia</option>
                                                                        <option value="Belum Tersedia" <%= row.status_ketersediaan === 'Belum Tersedia' ? 'selected' : '' %>>Belum Tersedia</option>
                                                                    </select>
                                                                </div>
                                                            </div>
                                                            <div class="modal-footer">
                                                                <button type="submit" class="btn btn-primary">Simpan Perubahan</button>
                                                            </div>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                            <!-- End Edit Modal -->
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Tambah Aspek -->
    <div class="modal fade text-start" id="addModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="/manajemen/aspek" method="POST">
                    <input type="hidden" name="action" value="add">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title"><i class="bi bi-plus-circle"></i> Tambah Aspek Baru</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Pilih Pilar</label>
                            <select name="kode_pilar" id="combo_pilar_m" class="form-select" required>
                                <option value="">-- Pilih Pilar --</option>
                                <% pilarList.forEach(p => { %>
                                    <option value="<%= p.kode_pilar %>"><%= p.kode_pilar %> - <%= p.nama_pilar %></option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Pilih Kelompok</label>
                            <select name="kode_kelompok" id="combo_kelompok_m" class="form-select" required disabled>
                                <option value="">-- Pilih Kelompok --</option>
                            </select>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Nama Aspek</label>
                            <input type="text" name="nama_aspek" class="form-control" placeholder="Contoh: Validasi" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Keterangan Aspek</label>
                            <textarea name="keterangan_aspek" class="form-control" rows="3" placeholder="Penjelasan tentang aspek ini..." required></textarea>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Status Ketersediaan</label>
                            <select name="status_ketersediaan" class="form-select" required>
                                <option value="Tersedia">Tersedia</option>
                                <option value="Belum Tersedia">Belum Tersedia</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                        <button type="submit" class="btn btn-primary">Simpan Data</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <!-- End Modal -->
</div>

<script>
document.addEventListener("DOMContentLoaded", function() {
    const dataKelompok = <%- JSON.stringify(kelompokList || []) %>;
    const cmbPilarM = document.getElementById("combo_pilar_m");
    const cmbKelompokM = document.getElementById("combo_kelompok_m");

    if (cmbPilarM && cmbKelompokM) {
        cmbPilarM.addEventListener("change", function() {
            cmbKelompokM.innerHTML = '<option value="">-- Pilih Kelompok --</option>';
            cmbKelompokM.disabled = true;

            const selectedPilar = this.value;
            if(selectedPilar && Array.isArray(dataKelompok)) {
                // Wait, dataKelompok from EJS only has kode_kelompok and nama_kelompok?
    document.addEventListener("DOMContentLoaded", function() {
        const comboPilar = document.getElementById('combo_pilar_m');
        const comboKelompok = document.getElementById('combo_kelompok_m');
        
        if(comboPilar) {
            comboPilar.addEventListener("change", function() {
                const pilarId = this.value;
                comboKelompok.innerHTML = '<option value="">-- Pilih Kelompok --</option>';
                comboKelompok.disabled = true;

                if (pilarId) {
                    fetch('/api/data').then(res => res.json()).then(data => {
                        const kelompokData = data.kelompok.filter(k => k.kode_pilar === pilarId);
                        if(kelompokData.length > 0) {
                            comboKelompok.disabled = false;
                            kelompokData.forEach(k => {
                                let opt = new Option(k.kode_kelompok + " - " + k.nama_kelompok, k.kode_kelompok);
                                comboKelompok.add(opt);
                            });
                        }
                    });
                }
            });
        }

        // Fitur Pencarian Aspek
        const searchInput = document.getElementById('searchAspek');
        if (searchInput) {
            searchInput.addEventListener('keyup', function() {
                const filter = searchInput.value.toLowerCase();
                const rows = document.querySelectorAll('table tbody tr');
                rows.forEach(row => {
                    // Cek jika ini baris "Belum ada aspek"
                    if (row.cells.length === 1) return;
                    
                    const text = row.textContent.toLowerCase();
                    row.style.display = text.includes(filter) ? '' : 'none';
                });
            });
        }
    });
</script>
