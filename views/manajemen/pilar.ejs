<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0 text-dark"><i class="bi bi-columns-gap"></i> Manajemen Pilar</h4>
    </div>

    <div class="row">
        <!-- Form Tambah -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0"><i class="bi bi-plus-circle"></i> Tambah Pilar</h6>
                </div>
                <div class="card-body">
                    <form action="/manajemen/pilar" method="POST">
                        <input type="hidden" name="action" value="add">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Kode Pilar</label>
                            <input type="text" name="kode_pilar" class="form-control" placeholder="Contoh: A" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Nama Pilar</label>
                            <input type="text" name="nama_pilar" class="form-control" placeholder="Contoh: SUPPLY" required>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Simpan Data</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Tabel Data -->
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white">
                    <h6 class="mb-0 fw-bold">Daftar Pilar</h6>
                </div>
                <div class="card-body table-responsive p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Kode</th>
                                <th>Nama Pilar</th>
                                <th class="text-end pe-3">Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(!data || data.length === 0) { %>
                                <tr><td colspan="3" class="text-center text-muted py-3">Belum ada pilar.</td></tr>
                            <% } else { %>
                                <% data.forEach(row => { %>
                                    <tr>
                                        <td class="ps-3"><span class="badge bg-dark"><%= row.kode_pilar %></span></td>
                                        <td class="fw-medium"><%= row.nama_pilar %></td>
                                        <td class="text-end pe-3">
                                            <form action="/manajemen/pilar" method="POST" class="d-inline" onsubmit="return confirm('Yakin hapus pilar ini? Data terkait di kelompok/aspek mungkin akan terpengaruh.')">
                                                <input type="hidden" name="action" value="delete">
                                                <input type="hidden" name="kode_pilar" value="<%= row.kode_pilar %>">
                                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
