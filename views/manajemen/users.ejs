<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0 text-dark"><i class="bi bi-people"></i> Manajemen User</h4>
    </div>

    <% if(error) { %>
        <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold">Daftar Pengguna</h6>
        </div>
        <div class="card-body table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Username</th>
                        <th>Role</th>
                        <th>Tanggal Dibuat</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(!data || data.length === 0) { %>
                        <tr><td colspan="4" class="text-center text-muted">Belum ada user.</td></tr>
                    <% } else { %>
                        <% data.forEach(row => { %>
                            <tr>
                                <td><%= row.id %></td>
                                <td><span class="fw-bold text-primary"><%= row.username %></span></td>
                                <td><span class="badge bg-secondary"><%= row.role %></span></td>
                                <td><small class="text-muted"><%= new Date(row.created_at).toLocaleString('id-ID') %></small></td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>
